rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function myUserLowerPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function myUserUpperPath() {
      return /databases/$(database)/documents/Users/$(request.auth.uid);
    }

    function hasMyLowerProfile() {
      return signedIn() && exists(myUserLowerPath());
    }

    function hasMyUpperProfile() {
      return signedIn() && exists(myUserUpperPath());
    }

    function myRole() {
      return hasMyLowerProfile()
        ? get(myUserLowerPath()).data.role
        : (hasMyUpperProfile() ? get(myUserUpperPath()).data.role : "");
    }

    function myCompanyId() {
      return hasMyLowerProfile()
        ? get(myUserLowerPath()).data.companyId
        : (hasMyUpperProfile() ? get(myUserUpperPath()).data.companyId : "");
    }

    function myCompanyName() {
      return hasMyLowerProfile()
        ? get(myUserLowerPath()).data.companyName
        : (hasMyUpperProfile() ? get(myUserUpperPath()).data.companyName : "");
    }

    function isCompanyAdmin() {
      return signedIn() && myRole() == "company_admin";
    }

    function isEmployerTeamRole() {
      return signedIn() && (
        myRole() == "employer" ||
        myRole() == "hr" ||
        myRole() == "finance" ||
        myRole() == "operation" ||
        myRole() == "operator"
      );
    }

    function isManagedEmployee() {
      return resource.data.createdByCompanyAdminUid == request.auth.uid
        && resource.data.companyId == myCompanyId();
    }

    match /users/{uid} {
      allow read: if signedIn() && (
        uid == request.auth.uid
        || (isCompanyAdmin() && resource.data.companyId == myCompanyId())
      );

      allow create: if signedIn() && uid == request.auth.uid;

      allow update: if signedIn() && (
        uid == request.auth.uid
        || (isCompanyAdmin() && isManagedEmployee())
      );

      allow delete: if signedIn() && (
        uid == request.auth.uid
        || (isCompanyAdmin() && isManagedEmployee())
      );
    }

    match /Users/{uid} {
      allow read: if signedIn() && (
        uid == request.auth.uid
        || (isCompanyAdmin() && resource.data.companyId == myCompanyId())
      );

      allow create: if signedIn() && uid == request.auth.uid;

      allow update: if signedIn() && (
        uid == request.auth.uid
        || (isCompanyAdmin() && isManagedEmployee())
      );

      allow delete: if signedIn() && (
        uid == request.auth.uid
        || (isCompanyAdmin() && isManagedEmployee())
      );
    }

    match /companies/{companyId} {
      allow read: if signedIn() && (
        (isCompanyAdmin() && companyId == myCompanyId())
        || resource.data.createdByUid == request.auth.uid
      );

      allow create: if isCompanyAdmin()
        && request.resource.data.id == companyId
        && request.resource.data.createdByUid == request.auth.uid;

      allow update: if isCompanyAdmin()
        && companyId == myCompanyId();

      allow delete: if false;
    }

    match /usernames/{usernameLower} {
      allow read: if signedIn();

      allow create, update: if signedIn() && (
        isCompanyAdmin()
        || request.resource.data.uid == request.auth.uid
      );

      allow delete: if signedIn() && (
        isCompanyAdmin()
        || resource.data.uid == request.auth.uid
      );
    }

    match /activity_logs/{logId} {
      allow create: if signedIn()
        && request.resource.data.actorUid == request.auth.uid;
      allow read: if signedIn();
      allow update, delete: if false;
    }

    match /jobs/{jobId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && isEmployerTeamRole()
        && request.resource.data.postedByUid == request.auth.uid
        && (
          (myCompanyId() == "" && request.resource.data.companyId == "")
          || request.resource.data.companyId == myCompanyId()
        );

      allow update, delete: if signedIn() && (
        resource.data.postedByUid == request.auth.uid
        || (isCompanyAdmin() && resource.data.companyId == myCompanyId())
        || (
          isEmployerTeamRole()
          && myCompanyId() != ""
          && resource.data.companyId == myCompanyId()
        )
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
